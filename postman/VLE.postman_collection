          "name": "Initialize Run + GET /api/data",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runStamp = Date.now().toString();",
                  "const runId = runStamp.slice(-5);",
                  "pm.environment.set('runId', runId);",
                  "pm.environment.set('createdCourseCode', `TST${runId}`);",
                  "pm.environment.set('createdStudentEmail', `postman.student.${runStamp}@vle.uwi.edu`);",
                  "pm.environment.unset('createdStudentID');",
                  "pm.environment.unset('createdStudentPassword');",
                  "pm.environment.unset('createdSectionID');",
                  "pm.environment.unset('createdSecItemID');",
                  "pm.environment.unset('createdForumID');",
                  "pm.environment.unset('createdThreadID');",
                  "pm.environment.unset('createdReplyID');",
                  "pm.environment.unset('createdSubmissionID');",
                  "pm.environment.unset('createdCalendarEventID');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "pm.test('message exists', function () { pm.expect(json).to.have.property('message'); });",
                  "pm.test('workflow variables initialized', function () { pm.expect(pm.environment.get('createdCourseCode')).to.match(/^TST\\d{5}$/); });"
